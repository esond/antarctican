DATA=/mnt/user/data
APPDATA=/mnt/user/appdata

# User and Group IDs
PUID=99
PGID=100

# Timezone
TZ=Etc/UTC

# qBittorrent
QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_TORRENTING_PORT=6881

# Jackett
JACKETT_AUTO_UPDATE=true
JACKETT_HOST_PORT=9117

# Sonarr
SONARR_HOST_PORT=8989

# Radarr
RADARR_HOST_PORT=7878

# FlareSolverr
FLARESOLVERR_LOG_LEVEL=info
FLARESOLVERR_HOST_PORT=8191

# Notifiarr
NOTIFIARR_HOST_PORT=5454

# Gluetun
GLUETUN_WIREGUARD_PRIVATE_KEY="goobermensch"
GLUETUN_WIREGUARD_ADDRESSES=x.x.x.x/32
GLUETUN_SERVER_CITIES=Arrakeen
GLUETUN_WIREGUARD_ENDPOINT_PORT=51820
GLUETUN_FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24

# Overseerr
OVERSEERR_LOG_LEVEL=debug
OVERSEERR_HOST_PORT=5055