APPDATA=/mnt/user/appdata

# User and Group IDs
PUID=99
PGID=100

# Timezone
TZ=Etc/UTC

# Krusader
KRUSADER_WEBUI_PORT=6080
KRUSADER_VNC_PORT=5900
KRUSADER_WEBPAGE_TITLE=Tower
KRUSADER_VNC_PASSWORD=your_vnc_password_here

# Dashdot
DASH_HOST_PORT=3001
DASHDOT_SHOW_DASH_VERSION=true
DASHDOT_ALWAYS_SHOW_PERCENTAGES=true
DASHDOT_PAGE_TITLE=Antarctican
DASHDOT_ENABLE_CPU_TEMPS=true

# Homarr
HOMARR_HOST_PORT=7575
HOMARR_SECRET_ENCRYPTION_KEY="generate new key using `openssl rand -hex 32`"